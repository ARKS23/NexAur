{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "nexaur",
  "version-string": "0.1.0",
  "description": "NexAur engine dependencies for the Vulkan renderer path.",
  "dependencies": [
    "assimp",
    {
      "name": "directx-dxc",
      "platform": "(windows & !arm32 & !uwp & !xbox) | (linux & x64)"
    },
    "entt",
    "fmt",
    "glfw3",
    "glm",
    {
      "name": "imgui",
      "features": [
        "docking-experimental",
        "glfw-binding",
        "vulkan-binding"
      ]
    },
    "imguizmo",
    "ktx",
    "nlohmann-json",
    "spdlog",
    "spirv-headers",
    "spirv-reflect",
    "stb",
    "tinygltf",
    "vk-bootstrap",
    "volk",
    "vulkan",
    "vulkan-memory-allocator"
  ]
}
